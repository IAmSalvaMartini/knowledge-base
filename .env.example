# =============================================================================
# Knowledge Base framework — environment template.
# Copy to .env and fill real values. NEVER commit .env (see .gitignore).
# All values below are PLACEHOLDERS, not real secrets.
# =============================================================================

# --- Generation backend (Anthropic enterprise; EDP / no-training terms) ------
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Provider selection: anthropic | openai_compatible
KB_LLM_PROVIDER=anthropic
KB_ANSWER_MODEL=claude-haiku-4-5-20251001
KB_ESCALATION_MODEL=claude-sonnet-4-6

# Optional: OpenAI-compatible / Copilot-style endpoint (only if KB_LLM_PROVIDER=openai_compatible)
# KB_OPENAI_BASE_URL=https://your-internal-gateway/v1
# KB_OPENAI_API_KEY=REPLACE_ME

# --- Embeddings ---------------------------------------------------------------
# KB_EMBED_BACKEND: ollama | sentence_transformers | dummy
#   ollama               — requires Ollama server running on-host (prod default)
#   sentence_transformers — pure pip install, no server (good for dev/work laptop)
#   dummy                — random vectors, pipeline runs but retrieval is meaningless
KB_EMBED_BACKEND=ollama
KB_EMBED_MODEL=nomic-embed-text
# sentence_transformers default model if KB_EMBED_MODEL is left as nomic-embed-text:
#   all-MiniLM-L6-v2 (~90 MB, downloads once on first run)
# For sentence_transformers, set KB_EMBED_MODEL=all-MiniLM-L6-v2 explicitly if preferred.
KB_OLLAMA_HOST=http://127.0.0.1:11434

# --- Retrieval / storage -----------------------------------------------------
KB_TOP_K=8
KB_CHROMA_PATH=./data/chroma

# --- Private content repo (Wiki.js Git storage; PRIVATE, do not publish) -----
# SSH URL of the internal knowledgebase-content repo and local clone path.
KB_CONTENT_REPO_URL=git@your-internal-host:org/knowledgebase-content.git
KB_CONTENT_MIRROR_PATH=./content_mirror

# Base URL of the internal Wiki.js instance (used to build citation links)
KB_WIKIJS_BASE_URL=https://wiki.internal.example

# --- SSO: Entra ID (Azure AD) OIDC -------------------------------------------
KB_OIDC_TENANT_ID=REPLACE_ME
KB_OIDC_CLIENT_ID=REPLACE_ME
KB_OIDC_CLIENT_SECRET=REPLACE_ME
KB_OIDC_REDIRECT_URI=http://127.0.0.1:5057/auth/callback
KB_FLASK_SECRET_KEY=REPLACE_ME

# --- CLI service token (non-interactive auth for `kb ask`) -------------------
KB_CLI_TOKEN=REPLACE_ME

# --- Uploads -----------------------------------------------------------------
KB_MAX_UPLOAD_MB=25
KB_UPLOADS_PATH=./data/uploads
